{
  "name": "@ikko-dev/gitlab-review",
  "version": "0.3.5",
  "description": "Run gitlab-review in GitLab CI and post deduplicated MR discussions.",
  "keywords": [
    "ci",
    "code-review",
    "gitlab",
    "gitlab-review",
    "merge-request"
  ],
  "homepage": "https://github.com/ikko-dev/gitlab-review#readme",
  "bugs": {
    "url": "https://github.com/ikko-dev/gitlab-review/issues"
  },
  "license": "FSL-1.1-ALv2",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ikko-dev/gitlab-review.git"
  },
  "bin": {
    "gitlab-review": "./bin/gitlab-review.js"
  },
  "files": [
    "bin/",
    "dist/",
    "skills/",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/review.d.ts",
      "default": "./dist/review.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsgo --emitDeclarationOnly",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:evals": "vitest run --config vite.eval.config.ts",
    "typecheck": "tsgo --noEmit",
    "typecheck:tests": "tsgo -p tsconfig.test.json --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:types": "oxlint --type-aware",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run typecheck:tests && npm test",
    "prepublishOnly": "npm run check && npm run build && npm pack --dry-run",
    "prepare": "husky"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.75.3",
    "@earendil-works/pi-ai": "0.75.3",
    "@earendil-works/pi-coding-agent": "0.75.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260304.1",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.4.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "vite": "^8.0.7",
    "vitest": "^4.1.0-beta.5",
    "vitest-evals": "^0.9.0"
  },
  "lint-staged": {
    "*.{js,ts,json,md,yml,yaml}": "oxfmt --write"
  },
  "engines": {
    "node": ">=24"
  }
}
