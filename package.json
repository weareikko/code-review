{
  "name": "@ikko-dev/gitlab-review",
  "version": "0.1.5",
  "description": "Run pi-reviewer in GitLab CI and post deduplicated MR discussions.",
  "keywords": [
    "ci",
    "code-review",
    "gitlab",
    "merge-request",
    "pi-reviewer"
  ],
  "homepage": "https://github.com/ikko-dev/gitlab-review#readme",
  "bugs": {
    "url": "https://github.com/ikko-dev/gitlab-review/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/ikko-dev/gitlab-review.git"
  },
  "bin": {
    "gitlab-review": "./bin/gitlab-review.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/review.d.ts",
      "default": "./dist/cli.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsgo --emitDeclarationOnly",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint:types": "oxlint --type-aware",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm test",
    "prepublishOnly": "npm run check && npm run build && npm pack --dry-run"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.75.3",
    "@earendil-works/pi-ai": "0.75.3",
    "@earendil-works/pi-coding-agent": "0.75.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260304.1",
    "@vitest/coverage-v8": "^4.1.6",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "vite": "^8.0.7",
    "vitest": "^4.1.0-beta.5"
  },
  "engines": {
    "node": ">=24"
  }
}
