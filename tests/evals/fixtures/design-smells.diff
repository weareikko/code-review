 // Formatting helpers for the storefront.

+type Money = { cents: number; currency: string };
+
+// Slugify a product name for its URL.
+export function slugifyProduct(name: string, id: number): string {
+  const base = name.trim().toLowerCase().replace(/\s+/g, '-');
+  return `${base}-${id}`;
+}
+
+// Slugify a category name for its URL.
+export function slugifyCategory(name: string, id: number): string {
+  const base = name.trim().toLowerCase().replace(/\s+/g, '-');
+  return `${base}-${id}`;
+}
+
+// Slugify a brand name for its URL.
+export function slugifyBrand(name: string, id: number): string {
+  const base = name.trim().toLowerCase().replace(/\s+/g, '-');
+  return `${base}-${id}`;
+}
+
+// Render a price for display. Reaches into Money's internals to format it
+// rather than asking Money to format itself.
+export function formatPrice(price: Money): string {
+  const amount = (price.cents / 100).toFixed(2);
+  return `${amount} ${price.currency}`;
+}
+
 export function joinName(first: string, last: string): string {
   return `${first} ${last}`;
 }
