--- a/src/accounts.ts
+++ b/src/accounts.ts
@@ -3,6 +3,38 @@ import type { Admin, Order, User } from './types.js';

 const MIN_NAME_LENGTH = 2;

+// Validate a new user before persisting.
+export function validateUser(user: User): string[] {
+  const errors: string[] = [];
+  if (!user.name || user.name.trim().length < MIN_NAME_LENGTH) {
+    errors.push('name too short');
+  }
+  if (!user.email.includes('@')) {
+    errors.push('email invalid');
+  }
+  if (user.age < 18) {
+    errors.push('must be 18+');
+  }
+  return errors;
+}
+
+// Validate a new admin before persisting.
+export function validateAdmin(admin: Admin): string[] {
+  const errors: string[] = [];
+  if (!admin.name || admin.name.trim().length < MIN_NAME_LENGTH) {
+    errors.push('name too short');
+  }
+  if (!admin.email.includes('@')) {
+    errors.push('email invalid');
+  }
+  if (admin.age < 18) {
+    errors.push('must be 18+');
+  }
+  return errors;
+}
+
+// Render the shipping line for a receipt.
+export function shippingLine(order: Order): string {
+  const street = order.customer.address.street;
+  const city = order.customer.address.city;
+  const zip = order.customer.address.zip;
+  const country = order.customer.address.country;
+  return `${street}, ${city} ${zip}, ${country}`;
+}
+
 export function accountLabel(user: User): string {
   return `${user.name} <${user.email}>`;
 }
