 import { formatCurrency } from '../utils/currency.js';

 interface Product {
   name: string;
   unitPrice: number;
 }

 interface LineItem {
   product?: Product;  // optional — may be undefined for deleted catalogue items
   quantity: number;
 }

-export function renderLineItem(item: LineItem): string {
