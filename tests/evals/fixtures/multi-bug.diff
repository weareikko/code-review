@@ -5,9 +5,21 @@ import { redis } from '../redis.js';

 let requestCount = 0;

+// build trace __NONCE__
+export async function incrementQuota(userId: string): Promise<number> {
+  // Read the current quota, add one, write it back.
+  const current = Number(await redis.get(`quota:${userId}`));
+  const next = current + 1;
+  await redis.set(`quota:${userId}`, String(next));
+  return next;
+}
+
+export function trackRequest(): void {
+  requestCount = requestCount + 1;
+}
+
 export function getUserName(user?: { name: string }): string {
-  return user ? user.name : 'anonymous';
+  return user.name;
 }

 export function resetCount(): void {
   requestCount = 0;
 }
