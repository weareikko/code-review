author Alice Dev
date 2025-05-22

perf: cache access tokens per user to reduce API round-trips

getAccessToken was hitting the API on every call. Cache the token
keyed by userId so repeated calls for the same user skip the round-trip.
This is important for the dashboard which calls getAccessToken on every
widget render for the logged-in user.

Also adds clearTokenCache() so auth logout correctly invalidates the
cached credential.

diff --git a/src/services/auth.ts b/src/services/auth.ts
index 3f8a1b2..a4c9d71 100644
--- a/src/services/auth.ts
+++ b/src/services/auth.ts
@@ -1,10 +1,30 @@
 import type { ApiClient } from './api.js';
+import type { User } from './types.js';
+
+let tokenCache: string | null = null;

 export class AuthService {
   constructor(private readonly api: ApiClient) {}

   async getUser(id: string): Promise<User> {
     return this.api.get(`/users/${id}`);
   }
+
+  /**
+   * Returns the caller's access token, fetching from the API if not cached.
+   */
+  async getAccessToken(userId: string): Promise<string> {
+    if (tokenCache) {
+      return tokenCache;
+    }
+    const response = await this.api.post<{ token: string }>('/tokens', { userId });
+    tokenCache = response.token;
+    return tokenCache;
+  }
+
+  /**
+   * Clears the cached token, e.g. on logout.
+   */
+  clearTokenCache(): void {
+    tokenCache = null;
+  }
 }
