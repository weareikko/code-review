+import type { EmailService, User } from './types.js';
+
+/**
+ * Send welcome emails to a batch of newly registered users.
+ */
+export async function sendWelcomeEmails(
+  users: User[],
+  emailService: EmailService,
+): Promise<void> {
+  users.forEach(async (user) => {
+    const template = await emailService.renderTemplate('welcome', { name: user.name });
+    await emailService.send({ to: user.email, subject: 'Welcome!', body: template });
+  });
+}
+
+/**
+ * Archive users whose accounts were created before cutoffDate.
+ * Returns the count of users archived.
+ */
+export async function archiveOldUsers(
+  users: User[],
+  cutoffDate: Date,
+): Promise<{ archived: number }> {
+  let archived = 0;
+  users
+    .filter((u) => new Date(u.createdAt) < cutoffDate)
+    .forEach(async (user) => {
+      await archiveUser(user.id);
+      archived += 1;
+    });
+  return { archived };
+}
