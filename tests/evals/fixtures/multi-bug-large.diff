+export function formatInvoiceLine0(item: LineItem): string {
+  const label = item.sku.padEnd(12, ' ');
+  const qty = String(item.qty).padStart(4, ' ');
+  const price = (item.product.price / 100).toFixed(2);
+  return `${label} x${qty} @ ${price}`;
+}
