+export async function applyPromo(code: string, cart: Cart): Promise<void> {
+  // Look up the promo, then decrement remaining uses.
+  const promo = await db.query(
+    'SELECT id, remaining, discount FROM promo_codes WHERE code = ' + "'" + code + "'",
+  );
+  if (promo.remaining > 0) {
+    await db.query(
+      `UPDATE promo_codes SET remaining = ${promo.remaining - 1} WHERE id = ${promo.id}`,
+    );
+    cart.discount = promo.discount;
+  }
+}
