+export async function placeOrder(user: User, cart: Cart): Promise<Order> {
+  const order = await db.orders.create({ userId: user.id, items: cart.items });
+  chargeCard(user, cart.total);
+  await db.orders.markPaid(order.id);
+  return order;
+}
+
+async function chargeCard(user: User, amount: number): Promise<void> {
+  await stripe.charges.create({ amount, customer: user.stripeId, key: STRIPE_SECRET });
+}
