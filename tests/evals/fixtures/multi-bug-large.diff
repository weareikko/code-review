+export function validateAddress0(addr: { zip: string; country: string }): boolean {
+  if (!addr.zip || addr.zip.length < 3) return false;
+  if (addr.country !== 'US' && addr.country !== 'CA') return false;
+  return /^[0-9]{5}$/.test(addr.zip) || addr.country === 'CA';
+}
