@@ -0,0 +1,29 @@
+interface Bucket {
+  tokens: number;
+  updatedAt: number;
+}
+
+const CAPACITY = 100;
+// tokens replenished per millisecond to reach CAPACITY over one minute
+const REFILL_PER_MS = CAPACITY / 60_000;
+
+const buckets = new Map<string, Bucket>();
+
+/**
+ * Token-bucket rate limiter. Returns whether the request for `token` is allowed
+ * and how many requests remain in the current window.
+ */
+export function checkRateLimit(token: string, now: number): { allowed: boolean; remaining: number } {
+  const bucket = buckets.get(token);
+  const elapsed = now - bucket.updatedAt;
+  const refilled = Math.min(CAPACITY, bucket.tokens + elapsed * REFILL_PER_MS);
+
+  if (refilled < 1) {
+    return { allowed: false, remaining: 0 };
+  }
+
+  buckets.set(token, { tokens: refilled - 1, updatedAt: now });
+  return { allowed: true, remaining: Math.floor(refilled - 1) };
+}
