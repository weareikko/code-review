+/**
+ * Subset of HTTP status codes used in this codebase. Add new entries
+ * here when a new code is referenced from application code so the type
+ * stays in sync with what callers can pass to the helpers below.
+ */
+export const HTTP_STATUS = {
+  OK: 200,
+  CREATED: 201,
+  NO_CONTENT: 204,
+  BAD_REQUEST: 400,
+  UNAUTHORIZED: 401,
+  FORBIDDEN: 403,
+  NOT_FOUND: 404,
+  CONFLICT: 409,
+  UNPROCESSABLE_ENTITY: 422,
+  INTERNAL_ERROR: 500,
+  BAD_GATEWAY: 502,
+  SERVICE_UNAVAILABLE: 503,
+} as const;
+
+export type HttpStatusCode = (typeof HTTP_STATUS)[keyof typeof HTTP_STATUS];
+
+/** True for any 4xx response. */
+export function isClientError(status: number): boolean {
+  return status >= 400 && status < 500;
+}
+
+/** True for any 5xx response. */
+export function isServerError(status: number): boolean {
+  return status >= 500 && status < 600;
+}
